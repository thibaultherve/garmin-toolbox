MCP_HOST=0.0.0.0
MCP_PORT=8769
LOG_LEVEL=INFO

# InfluxDB connection (same as garmin-fetch-data)
INFLUXDB_HOST=influxdb
INFLUXDB_PORT=8086
INFLUXDB_DATABASE=GarminStats
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change_me

# Athlete physiological parameters
# Find yours in Garmin Connect > Settings > User Settings > Heart Rate Zones
ATHLETE_HR_MAX=190
ATHLETE_HR_REST=50

# Activity dump paths (optional — defaults work for Docker)
# ACTIVITY_DUMP_PATH=/app/activities
# ACTIVITY_DUMP_SMB=\\\\YOUR_NAS_IP\\share\\garmin-toolbox\\activities

# Garmin Connect token cache path (shared with garmin-fetch-data)
# GARMIN_TOKEN_PATH=./data/tokens
